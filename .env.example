ENVIRONMENT=development
BLOCKCHAIN_ADAPTER=mock

POSTGRES_DB=massai_monitoring
POSTGRES_USER=massai
POSTGRES_PASSWORD=massai
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://massai:massai@postgres:5432/massai_monitoring

API_URL=http://backend:8000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
BACKEND_PORT=8000

KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=massai
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_PORT=8080
PROVIDER_FACTOR_CLIENT_SECRET=provider-factor-sa-secret
PROVIDER_TASOWHEEL_CLIENT_SECRET=provider-tasowheel-sa-secret
PROVIDER_E4M_CLIENT_SECRET=provider-e4m-sa-secret

FRONTEND_PORT=3000
SIMULATOR_INTERVAL_SECONDS=15

# SECURITY NOTE: massai-frontend has directAccessGrantsEnabled=true in the dev realm.
# This is intentional for local curl-based testing only. Disable it in production.
